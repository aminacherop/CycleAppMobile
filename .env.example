# ─────────────────────────────────────────────────────────────
#  AdMob IDs — copy this file to `.env` and fill in your REAL ids.
#  `.env` is gitignored, so real ids are never pushed to GitHub.
#  Anything you leave blank falls back to Google's TEST ids.
#
#  Local builds read `.env` automatically. For EAS cloud builds you
#  must also add these as EAS environment variables (see below).
# ─────────────────────────────────────────────────────────────

# App IDs (from AdMob → App settings). Format: ca-app-pub-XXXX~YYYY
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_IOS_APP_ID=

# Ad-unit IDs (from AdMob → each ad unit). Format: ca-app-pub-XXXX/ZZZZ
EXPO_PUBLIC_ADMOB_ANDROID_APPOPEN=
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL=
EXPO_PUBLIC_ADMOB_ANDROID_BANNER=
EXPO_PUBLIC_ADMOB_ANDROID_NATIVE=

EXPO_PUBLIC_ADMOB_IOS_APPOPEN=
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL=
EXPO_PUBLIC_ADMOB_IOS_BANNER=
EXPO_PUBLIC_ADMOB_IOS_NATIVE=
